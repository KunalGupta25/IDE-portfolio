# =============================================================================
# CLERK AUTHENTICATION
# https://dashboard.clerk.com → Your App → API Keys
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (optional — defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/guest-book
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/guest-book


# =============================================================================
# DATABASE — PostgreSQL via Prisma
# Recommended: Vercel Postgres / Neon / Supabase
# =============================================================================

# Pooled connection (used by Prisma Client at runtime)
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connect_timeout=15

# Direct connection (used for migrations — no connection pooler)
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST:PORT/DATABASE


# =============================================================================
# GITHUB — Personal Access Token
# https://github.com/settings/tokens
# Required scopes: read:user, repo (public)
# Used for: profile stats, contribution calendar, commit history
# =============================================================================
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# RESEND — Email Delivery
# https://resend.com/api-keys
# Used for: Contact form email submissions
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# IP GEOLOCATION — Astronomy Data (Sun/Moon position)
# https://ipgeolocation.io/documentation/astronomy-api.html
# Used for: Real-time sun/moon position and shadow effect on IDE window
# =============================================================================
IP_GEOLOCATION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# DATADOG — Real User Monitoring (RUM)
# https://app.datadoghq.com/rum/application/create
# Note: applicationId and clientToken are currently hardcoded in
#       src/components/datadog/datadog-init.tsx — move them here for best practice
# =============================================================================
NEXT_PUBLIC_DATADOG_APPLICATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=pubxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# WAKATIME (No API key required)
# The app uses WakaTime public share URLs — no secret key needed.
# Share URLs are configured directly in src/lib/wakatime.ts
# =============================================================================
